page {
  min-height: 100%;
  background: #e6fffa;
  color: #15313a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  border-radius: 8rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 32rpx;
}

.panel {
  background: #ffffff;
  border: 2rpx solid rgba(21, 49, 58, 0.08);
  border-radius: 12rpx;
  box-shadow: 0 12rpx 36rpx rgba(15, 82, 95, 0.08);
}

.primary-button {
  color: #ffffff;
  background: #0e7490;
}

.secondary-button {
  color: #0e7490;
  background: #ecfeff;
  border: 2rpx solid #67e8f9;
}

.danger-text {
  color: #be123c;
}
