<view class="page home-page">
  <view class="brand">
    <view class="title">单词捕鱼</view>
    <view class="subtitle">双人联机对战 · 60 秒抢分</view>
  </view>

  <view class="panel form-panel">
    <view class="field">
      <text class="label">玩家昵称</text>
      <input class="input" maxlength="12" placeholder="输入你的昵称" value="{{playerName}}" bindinput="onNameInput" />
    </view>

    <button class="primary-button action" loading="{{creating}}" bindtap="createRoom">创建房间</button>

    <view class="divider"></view>

    <view class="field">
      <text class="label">房间码</text>
      <input class="input code-input" maxlength="6" placeholder="输入 6 位房间码" value="{{roomCode}}" bindinput="onCodeInput" />
    </view>
    <button class="secondary-button action" loading="{{joining}}" bindtap="joinRoom">加入房间</button>
  </view>
</view>
