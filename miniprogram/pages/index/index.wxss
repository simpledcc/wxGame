.home-page {
  display: flex;
  flex-direction: column;
  gap: 36rpx;
  background: linear-gradient(180deg, #cffafe 0%, #f8fafc 80%);
}

.brand {
  padding-top: 48rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.15;
  color: #155e75;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #475569;
}

.form-panel {
  padding: 32rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #334155;
}

.input {
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 30rpx;
}

.code-input {
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.action {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.divider {
  height: 2rpx;
  margin: 32rpx 0;
  background: #e2e8f0;
}
